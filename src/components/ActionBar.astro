---
---

<section class="section action-bar" id="action-bar" hidden>
  <button class="btn btn--accent" id="regen-keys-btn">[REGERAR CHAVES]</button>
  <button class="btn btn--accent" id="download-all-btn">[BAIXAR TUDO .zip]</button>
  <button class="btn" id="copy-all-btn">[COPIAR TUDO]</button>
</section>

<style>
  .action-bar {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
  }
</style>

<script>
  import { subscribe, getState, regenerateAllKeys } from '../lib/store';
  import {
    generateAllConfigs,
    generateKeySummary,
  } from '../lib/config-generator';
  import { copyToClipboard } from '../lib/clipboard';
  import { downloadZip } from '../lib/zip';

  const section = document.getElementById('action-bar')!;
  const regenBtn = document.getElementById('regen-keys-btn')!;
  const dlAllBtn = document.getElementById('download-all-btn')!;
  const copyAllBtn = document.getElementById('copy-all-btn')!;

  regenBtn.addEventListener('click', async () => {
    regenBtn.textContent = '[GERANDO...]';
    regenBtn.setAttribute('disabled', '');
    await regenerateAllKeys();
    regenBtn.removeAttribute('disabled');
    regenBtn.textContent = '[REGERAR CHAVES]';
  });

  dlAllBtn.addEventListener('click', () => {
    const state = getState();
    const configs = generateAllConfigs(state.peers, state.network);
    const keys = generateKeySummary(state.peers, state.network);

    const entries = [
      ...configs.map((c) => ({ filename: c.filename, content: c.content })),
      { filename: 'keys.txt', content: keys },
    ];

    downloadZip(entries, 'wireguard-configs.zip');
  });

  copyAllBtn.addEventListener('click', async () => {
    const state = getState();
    const configs = generateAllConfigs(state.peers, state.network);
    const allText = configs.map((c) => `# --- ${c.filename} ---\n${c.content}`).join('\n\n');
    const ok = await copyToClipboard(allText);
    copyAllBtn.textContent = ok ? '[COPIADO!]' : '[ERRO]';
    setTimeout(() => (copyAllBtn.textContent = '[COPIAR TUDO]'), 1500);
  });

  subscribe((state) => {
    section.hidden = state.peers.length === 0;
  });
  section.hidden = getState().peers.length === 0;
</script>
