<style>
  .footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border);
  }

  .footer__text {
    font-size: 1rem;
    color: var(--text-muted);
  }

  .footer__sponsor {
    margin-top: 0.75rem;
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .footer__sponsor a {
    color: var(--accent);
    transition: opacity var(--transition);
  }

  .footer__sponsor a:hover {
    opacity: 0.8;
  }

  .footer__links {
    margin-top: 0.5rem;
    font-size: 1rem;
  }

  .footer__links a {
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .footer__links a:hover {
    color: var(--accent);
  }

  .footer__sep {
    margin: 0 0.5rem;
    color: var(--border);
  }
